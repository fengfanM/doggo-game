# Set default behavior for text files
* text=auto

# Explicitly set text files to always be normalized
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.scss text eol=lf
*.css text eol=lf
*.html text eol=lf

# Explicitly set binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.svg binary
*.mp4 binary
*.mov binary
*.zip binary
*.tar.gz binary

